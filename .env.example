# BscScan API — free at https://bscscan.com/myapikey (used for token contract info)
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Moralis Web3 API — free at https://admin.moralis.io (used for wallet portfolio scan)
MORALIS_API_KEY=your_moralis_api_key_here

# DGrid AI Gateway — https://dgrid.io (primary LLM, used for DGrid bounty integration)
DGRID_API_KEY=your_dgrid_api_key_here
DGRID_BASE_URL=https://api.dgrid.ai/v1

# Anthropic API — https://console.anthropic.com/settings/keys (fallback if DGrid is unavailable)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Public app URL (update to your Vercel deployment URL after deploying)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
